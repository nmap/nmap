#!/usr/bin/env bash
set -euo pipefail

if python3 -c "import zenmap.linux.native.app" >/dev/null 2>&1; then
  exec python3 -m zenmap.linux.native.app "$@"
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"
export PYTHONPATH="${REPO_ROOT}${PYTHONPATH:+:${PYTHONPATH}}"
exec python3 -m zenmap.linux.native.app "$@"
