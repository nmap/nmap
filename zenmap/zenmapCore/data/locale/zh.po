msgstr "安全"

msgid "intrusive"
msgstr "入侵"

msgid "malware"
msgstr "恶意软件"

msgid "discovery"
msgstr "发现"

msgid "vuln"
msgstr "漏洞"

msgid "auth"
msgstr "认证"

msgid "external"
msgstr "外部"

msgid "default"
msgstr "默认"

msgid "broadcast"
msgstr "广播"

msgid "dos"
msgstr "拒绝服务"

msgid "exploit"
msgstr "利用"

msgid "fuzzer"
msgstr "模糊测试"

